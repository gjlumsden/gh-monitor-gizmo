# Wi-Fi (shared across all ESPHome devices)
wifi_ssid: "your-ssid"
wifi_password: "your-wifi-password"

# GitHub API
# Personal access token used to raise the rate limit on /users/{user}/events
# and to power the extra info cards. Any card whose permission is missing is
# silently disabled the first time it fails; nothing is retried until reboot.
#
#   Fine-grained PAT permissions (recommended):
#     Card                        | Permission                      | Required?
#     ----------------------------|---------------------------------|----------
#     Events / CI                 | (none; default Metadata:RO)     | default
#     Contributions + PRs (stats) | Contents: Read-only             | optional
#                                 |   + "Include private contribs"  |
#                                 |   checkbox on GitHub profile    |
#     Copilot billing usage       | Plan: Read-only                 | optional
#     API rate-limit card         | (any token works)               | always
#
#   Classic PAT equivalents:
#     repo                        -> private-repo events + stats
#     manage_billing:copilot      -> billing card
ghgizmo_github_user: "your-github-username"
ghgizmo_github_token: "github_pat_xxx_or_ghp_xxx"

# ESPHome device secrets
#
# ghgizmo_api_encryption_key is read only by the `-ha.yaml` builds
# (Home Assistant variant). It is completely unreferenced by the
# `-standalone.yaml` builds and can be omitted when flashing only the
# standalone variant. Generate a fresh base64-32-byte key here:
# https://esphome.io/components/api.html
ghgizmo_api_encryption_key: "base64-32-byte-key"
# Any password you like; used for OTA updates (both variants).
ghgizmo_ota_password: "some-long-random-string"
# Fallback AP password shown if Wi-Fi can't connect (both variants).
# The standalone variant also exposes a captive portal on this AP for
# re-entering Wi-Fi credentials without a reflash.
ghgizmo_ap_password: "some-other-random-string"
